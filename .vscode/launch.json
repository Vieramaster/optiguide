{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Next.js: debug server",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "npm",
        "runtimeArgs": ["run", "dev"],
        "console": "integratedTerminal",

      },
      {
        "name": "Next.js: debug client (Edge)",
        "type": "msedge",
        "request": "launch",
        "url": "http://localhost:3000",
        "webRoot": "${workspaceFolder}"
      },
      {
        "name": "Next.js: fullstack",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "npm",
        "runtimeArgs": ["run", "dev"],
        "console": "integratedTerminal",
        "serverReadyAction": {
          "pattern": "started server on.*(http://localhost:3000)",
          "uriFormat": "%s",
          "action": "debugWithEdge"
        }
      }
    ]
  }